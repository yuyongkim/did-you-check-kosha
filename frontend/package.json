{
  "name": "epc-maintenance-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3012",
    "clean:cache": "node -e \"const fs=require('fs');['.next','.next-dev'].forEach((d)=>fs.rmSync(d,{recursive:true,force:true}));\"",
    "dev:fresh": "npm run clean:cache && next dev -p 3012",
    "build": "next build",
    "start": "next start -p 3012",
    "lint": "next lint",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:backend": "playwright test tests/e2e/backend-mode-seven.spec.ts",
    "qa": "npm run lint && npm run typecheck && npm run test:unit && npm run test:e2e && npm run build"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "katex": "^0.16.33",
    "lucide-react": "^0.453.0",
    "next": "^14.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.53.0",
    "react-katex": "^3.1.0",
    "recharts": "^2.12.7",
    "tailwind-merge": "^2.5.2",
    "zod": "^3.23.8",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^20.16.5",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.0",
    "jsdom": "^26.1.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.2",
    "vitest": "^2.1.2"
  }
}

# KOSHA integration
KOSHA_REGULATORY_ENABLED=true

# Use one of encoded/decoded/service key. Encoded key is accepted and decoded internally.
KOSHA_API_KEY_ENCODING=YOUR_DATA_GO_KR_ENCODED_SERVICE_KEY
KOSHA_API_KEY_DECODING=YOUR_DATA_GO_KR_DECODED_SERVICE_KEY

# Endpoints
KOSHA_GUIDE_API_ENDPOINT=https://apis.data.go.kr/B552468/koshaguide
KOSHA_SMART_SEARCH_API_ENDPOINT=https://apis.data.go.kr/B552468/srch/smartSearch

# Runtime options
KOSHA_API_TIMEOUT_MS=5500
KOSHA_CACHE_TTL_MS=300000

# Local RAG panel (frontend -> python bridge)
KOSHA_LOCAL_RAG_ENABLED=true
KOSHA_RAG_PYTHON_BIN=python
KOSHA_RAG_SCRIPT=../scripts/kosha_rag_local.py
KOSHA_RAG_INDEX_PATH=../datasets/kosha_rag/kosha_local_rag.sqlite3
KOSHA_RAG_QUERY_TIMEOUT_MS=20000
KOSHA_RAG_DEFAULT_TOP_K=6
KOSHA_RAG_MAX_CONTEXT=5
KOSHA_RAG_MODEL=qwen2.5:7b-instruct
KOSHA_RAG_GENERATE=false

# Existing frontend optional settings
NEXT_PUBLIC_BACKEND_API_PREFIX=
